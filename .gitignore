# Git ignore file
# Ignore node modules, build output, env files, and OS-specific files
node_modules/
dist/
build/
.env
.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

# Ignore generated files
*.class
*.jar
*.war
*.dll
*.exe
*.out

# Ignore temporary files
*.tmp
*.temp
~*