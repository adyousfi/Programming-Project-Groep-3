<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Configure IIS to use iisnode for server.js -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    
    <rewrite>
      <rules>
        <!-- Route all requests to server.js -->
        <rule name="Node.js Express Routing" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment=".env" />
        </hiddenSegments>
      </requestFiltering>
    </security>
    
    <!-- Disable logging to prevent HRESULT 0x2 crashes if permissions are missing -->
    <iisnode loggingEnabled="false" devErrorsEnabled="true" watchedFiles="web.config;server.js;backend\server.js" />
  </system.webServer>
</configuration>
